{
  "version": 6,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "C++ only",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "python",
      "displayName": "C++ with Python bindings",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_PYTHON_BINDINGS": "ON",
        "BUILD_LibraryFEMTHERM_TESTING": "ON"
      }
    }
  ]
}
